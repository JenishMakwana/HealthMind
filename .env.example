# HealthMind backend environment example
# Copy this file to `.env` and fill in real values as needed.

APP_NAME=HealthMind
APP_VERSION=1.0.0
DEBUG=false

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION_NAME=medical-knowledge-rag
QDRANT_NAMESPACE=medical-docs
QDRANT_VECTOR_SIZE=768

GROQ_API_KEY=
GOOGLE_API_KEY=
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
EMBEDDING_MODEL=NeuML/pubmedbert-base-embeddings

STT_ENABLED=true
STT_MODEL=Qwen/Qwen3-ASR-1.7B
STT_DEVICE=auto
STT_DTYPE=auto
STT_MAX_NEW_TOKENS=256
STT_CONTEXT=
STT_LANGUAGE=en
SPEECH_MAX_UPLOAD_MB=25

RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5
RERANKER_MAX_CHUNKS_PER_DOC=2
RERANKER_MIN_SCORE=-1.0
RERANKER_SCORE_WINDOW=1.5

RAG_RETRIEVAL_TOP_K=20
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_CONVERSATION_HISTORY_TURNS=6
RAG_HYBRID_RRF_K=60

DATABASE_URL=sqlite+aiosqlite:///./data/healthmind_main.db
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
